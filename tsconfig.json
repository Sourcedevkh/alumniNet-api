{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "middlewares/**/*.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "controllers",
    "routes",
    "models",
    "database"
  ]
}